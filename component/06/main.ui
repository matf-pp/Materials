<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="windowTitle">
   <string>Layout Buttons Example</string>
  </property>

  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="mainLayout">

    <!-- Title -->
    <item>
     <widget class="QLabel" name="label_title">
      <property name="text">
       <string>Simple Layout Example</string>
      </property>
      <property name="alignment">
       <set>Qt::AlignCenter</set>
      </property>
     </widget>
    </item>

    <!-- First row of buttons -->
    <item>
     <layout class="QHBoxLayout" name="topButtonLayout">
      <item>
       <widget class="QPushButton" name="btn_one">
        <property name="text">
         <string>Button One</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="btn_two">
        <property name="text">
         <string>Button Two</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="btn_three">
        <property name="text">
         <string>Button Three</string>
        </property>
       </widget>
      </item>
     </layout>
    </item>

    <!-- Status label -->
    <item>
     <widget class="QLabel" name="label_status">
      <property name="text">
       <string>Status: Ready</string>
      </property>
     </widget>
    </item>

    <!-- Bottom action buttons -->
    <item>
     <layout class="QHBoxLayout" name="bottomButtonLayout">
      <item>
       <spacer name="horizontalSpacer">
        <property name="orientation">
         <enum>Qt::Horizontal</enum>
        </property>
        <property name="sizeHint">
         <size>
          <width>40</width>
          <height>20</height>
         </size>
        </property>
       </spacer>
      </item>
      <item>
       <widget class="QPushButton" name="btn_ok">
        <property name="text">
         <string>OK</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="btn_cancel">
        <property name="text">
         <string>Cancel</string>
        </property>
       </widget>
      </item>
     </layout>
    </item>

   </layout>
  </widget>
 </widget>

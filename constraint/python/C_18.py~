from constraint import *

def valid(M,A,N,E,T,I,S,R,O):
    # Prvi brojevi ne smeju biti 0
    if M == 0 or R == 0:
        return False

    MANET   = M*10000 + A*1000 + N*100 + E*10 + T
    MATISSE = M*10000000 + A*1000000 + T*100000 + I*10000 + S*1000 + S*100 + E*10 + E
    MIRO    = M*1000 + I*100 + R*10 + O
    MONET   = M*10000 + O*1000 + N*100 + E*10 + T
    RENOIR  = R*100000 + E*10000 + N*1000 + O*100 + I*10 + R
    ARTISTS = A*1000000 + R*100000 + T*10000 + I*1000 + S*100 + T*10 + S

    return MANET + MATISSE + MIRO + MONET + RENOIR == ARTISTS

problem = Problem()

# Sva slova u jednačini
letters = "MANETISRO"
problem.addVariables(letters, range(10))

# Ograničenje: svi različiti
problem.addConstraint(AllDifferentConstraint(), letters)

# Ograničenje: validna jednačina
problem.addConstraint(valid, letters)

# Pronađi prvo rešenje
for s in problem.getSolutions():
    MANET   = s['M']*10000 + s['A']*1000 + s['N']*100 + s['E']*10 + s['T']
    MATISSE = s['M']*10000000 + s['A']*1000000 + s['T']*100000 + s['I']*10000 + s['S']*1000 + s['S']*100 + s['E']*10 + s['E']
    MIRO    = s['M']*1000 + s['I']*100 + s['R']*10 + s['O']
    MONET   = s['M']*10000 + s['O']*1000 + s['N']*100 + s['E']*10 + s['T']
    RENOIR  = s['R']*100000 + s['E']*10000 + s['N']*1000 + s['O']*100 + s['I']*10 + s['R']
    ARTISTS = s['A']*1000000 + s['R']*100000 + s['T']*10000 + s['I']*1000 + s['S']*100 + s['T']*10 + s['S']

    print(f"MANET = {MANET}")
    print(f"MATISSE = {MATISSE}")
    print(f"MIRO = {MIRO}")
    print(f"MONET = {MONET}")
    print(f"RENOIR = {RENOIR}")
    print(f"ARTISTS = {ARTISTS}")
    break  # samo prvo rešenje
